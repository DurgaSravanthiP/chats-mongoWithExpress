<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Whatsapp</title>
    <link rel="stylesheet" href="style.css" />
</head>

<body>
    <h3>All Chats!</h3>
    <form method="GET" action="/chats/new">
        <button>New Chat</button>
    </form>
    <br>
    <% for(let chat of chats){ %>
        <div class="chat">
            <p>From: <i>
                    <%= chat.from %>
                </i>
            </p>
            <div class="msg">
                <p>
                    <%= chat.msg %>
                        <form method="get" action="/chats/<%= chat._id%>/edit">
                            <button>Edit</button>
                        </form>
                        <br>
                        <form method="post" action="/chats/<%= chat._id%>?_method=DELETE">
                            <button>Delete</button>
                        </form>
                        <br>
                        <form method="get" action="/chats/<%= chat._id%>">
                            <button>Show</button>
                        </form>
                </p>
            </div>
            <p>Received by <i>
                    <%= chat.to %>
                </i>
            </p>
            <p>
                <%= chat.created_at.toString().split(" ")[4] %>
                <br/>
                <%= chat.created_at.toString().split(" ").slice(0,4).join(" ") %>
                <br/>
            </p>
            <hr>
        </div>
        <br><br>
        <% } %>
</body>

</html>